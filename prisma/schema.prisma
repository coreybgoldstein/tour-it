// ============================================================
// Tour It — Production Prisma Schema
// PostgreSQL | Prisma ORM
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}
// ============================================================
// ENUMS
// ============================================================

enum TeeColor {
  BLACK
  BLUE
  WHITE
  GOLD
  RED
  GREEN
  CUSTOM
}

enum CourseType {
  PUBLIC
  PRIVATE
  SEMI_PRIVATE
}

enum MediaType {
  VIDEO
  PHOTO
}

enum ShotType {
  TEE_SHOT
  APPROACH
  LAY_UP
  CHIP
  PITCH
  PUTT
  BUNKER
  RECOVERY
  FULL_HOLE
  FLYOVER
  FRONT_NINE
  BACK_NINE
  FULL_ROUND
  THREE_HOLE
}

enum LieType {
  FAIRWAY
  ROUGH
  BUNKER
  HARDPAN
  PINE_STRAW
  NATIVE
  TEE_BOX
  GREEN
}

enum WindCondition {
  CALM
  LIGHT
  MODERATE
  STRONG
  INTO
  DOWNWIND
  LEFT_TO_RIGHT
  RIGHT_TO_LEFT
}

enum HandicapRange {
  SCRATCH
  LOW
  MID
  HIGH
  BOGEY
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED
}

enum ReportReason {
  INAPPROPRIATE
  SPAM
  WRONG_HOLE
  WRONG_COURSE
  LOW_QUALITY
  COPYRIGHT
  OTHER
}

enum FollowStatus {
  ACTIVE
  BLOCKED
}

enum RankTier {
  CADDIE
  LOCAL
  MARSHAL
  COURSE_PRO
  TOUR_PRO
  LEGEND
}

enum BadgeCategory {
  CONTRIBUTION
  SOCIAL
  EXPLORER
  ACHIEVEMENT
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum LeaderboardPeriod {
  WEEKLY
  MONTHLY
  ALL_TIME
}

// ============================================================
// USER
// ============================================================

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  username         String   @unique
  displayName      String
  avatarUrl        String?
  bannerUrl        String?
  bio              String?
  handicapIndex    Float?
  homeCourseId     String?
  pushSubscription String?
  isVerified       Boolean  @default(false)
  isAdmin          Boolean  @default(false)
  uploadCount      Int      @default(0)
  reputationScore  Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  uploads          Upload[]
  rounds           Round[]
  uploadPhotos     UploadPhoto[]
  comments         Comment[]
  likes            Like[]
  saves            Save[]
  views            View[]
  reports          ModerationReport[] @relation("ReportedBy")
  receivedReports  ModerationReport[] @relation("ReportedUser")
  followers        Follow[]           @relation("Following")
  following        Follow[]           @relation("Follower")
  homeCourse       Course?            @relation("HomeCourse", fields: [homeCourseId], references: [id])
  createdTrips     GolfTrip[]         @relation("CreatedTrips")
  tripMemberships  GolfTripMember[]   @relation("TripMemberships")
  notifications    Notification[]
  uploadTags       UploadTag[]
  progression      UserProgression?
  pointsLedger     UserPointsLedger[]
  badges           UserBadge[]
  courseContributions CourseContribution[]

  @@index([username])
  @@index([email])
  @@index([reputationScore(sort: Desc)])
}

// ============================================================
// COURSE
// ============================================================

model Course {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  city          String
  state         String
  country       String   @default("US")
  latitude      Float?
  longitude     Float?
  websiteUrl    String?
  phone         String?
  description   String?
  holeCount     Int      @default(18)
  isPublic      Boolean  @default(true)
  courseType    CourseType?
  zipCode       String?
  yearEstablished Int?
  isVerified    Boolean  @default(false)
  coverImageUrl     String?
  logoUrl           String?
  scorecardImageUrl String?
  searchVector      String?
  uploadCount   Int      @default(0)
  saveCount     Int      @default(0)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  holes         Hole[]
  saves         Save[]
  views         View[]
  homeUsers     User[]   @relation("HomeCourse")
  teeBoxes      TeeBox[]

  @@index([state])
  @@index([city, state])
  @@index([slug])
  @@index([isPublic])
  @@index([uploadCount(sort: Desc)])
}

// ============================================================
// HOLE
// ============================================================

model Hole {
  id           String   @id @default(cuid())
  courseId     String
  holeNumber   Int
  par          Int
  handicapRank Int?
  description  String?
  imageUrl     String?
  uploadCount  Int      @default(0)
  yardage      Int?
  teeLat       Float?
  teeLng       Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teeBoxes     TeeBox[]
  uploads      Upload[]

  @@unique([courseId, holeNumber])
  @@index([courseId])
  @@index([holeNumber])
}

// ============================================================
// TEE BOX
// ============================================================

model TeeBox {
  id          String    @id @default(cuid())
  courseId    String
  holeId      String
  color       TeeColor
  customLabel String?
  yardage     Int
  rating      Float?
  slope       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  hole        Hole      @relation(fields: [holeId], references: [id], onDelete: Cascade)
  uploads     Upload[]

  @@unique([holeId, color])
  @@index([holeId])
  @@index([courseId])
}

// ============================================================
// UPLOAD
// ============================================================

model Upload {
  id                   String           @id @default(cuid())
  userId               String
  courseId             String
  holeId               String
  teeBoxId             String?

  mediaType            MediaType
  mediaUrl             String
  cloudflareVideoId    String?
  thumbnailUrl         String?
  durationSeconds      Int?
  fileSizeBytes        BigInt?
  resolution           String?

  shotType             ShotType?
  clubUsed             String?
  distancePlayed       Int?
  windCondition        WindCondition?
  conditions           String?
  lieType              LieType?
  handicapRange        HandicapRange?
  strategyNote         String?
  landingZoneNote      String?
  whatCameraDoesntShow String?
  datePlayedAt         DateTime?

  caption              String?
  seriesId             String?
  seriesOrder          Int?
  yardageOverlay       String?
  tripId               String?
  tripPublic           Boolean          @default(true)

  clipLat              Float?
  clipLng              Float?

  likeCount            Int              @default(0)
  commentCount         Int              @default(0)
  viewCount            Int              @default(0)
  saveCount            Int              @default(0)
  watchCompletionRate  Float?
  rankScore            Float            @default(0)

  moderationStatus     ModerationStatus @default(PENDING)
  moderatedAt          DateTime?
  moderatedBy          String?

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  roundId              String?

  user                 User             @relation(fields: [userId], references: [id])
  hole                 Hole             @relation(fields: [holeId], references: [id])
  teeBox               TeeBox?          @relation(fields: [teeBoxId], references: [id])
  round                Round?           @relation(fields: [roundId], references: [id])
  photos               UploadPhoto[]
  comments             Comment[]
  likes                Like[]
  views                View[]
  reports              ModerationReport[]

  @@index([holeId])
  @@index([courseId])
  @@index([userId])
  @@index([holeId, rankScore(sort: Desc)])
  @@index([holeId, teeBoxId, rankScore(sort: Desc)])
  @@index([moderationStatus])
  @@index([createdAt(sort: Desc)])
  @@index([seriesId])
}

// ============================================================
// ROUND
// ============================================================

model Round {
  id          String   @id @default(cuid())
  userId      String
  courseId    String
  date        String
  totalScore  Int?
  fairwaysHit Int?
  putts       Int?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads     Upload[]

  @@index([userId])
  @@index([courseId])
}

// ============================================================
// UPLOAD PHOTO
// ============================================================

model UploadPhoto {
  id        String   @id @default(cuid())
  uploadId  String
  userId    String
  photoUrl  String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([uploadId])
}

// ============================================================
// COMMENT
// ============================================================

model Comment {
  id        String   @id @default(cuid())
  uploadId  String
  userId    String
  body      String
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  likes     Like[]

  @@index([uploadId, createdAt(sort: Desc)])
  @@index([userId])
}

// ============================================================
// LIKE
// ============================================================

model Like {
  id        String   @id @default(cuid())
  userId    String
  uploadId  String?
  commentId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  upload    Upload?  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, uploadId])
  @@unique([userId, commentId])
  @@index([uploadId])
  @@index([userId])
}

// ============================================================
// SAVE
// ============================================================

model Save {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  uploadId  String?
  saveType  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@unique([userId, uploadId])
  @@index([userId])
  @@index([courseId])
}

// ============================================================
// VIEW
// ============================================================

model View {
  id        String   @id @default(cuid())
  userId    String?
  uploadId  String?
  courseId  String?
  sessionId String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  upload    Upload?  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([uploadId, createdAt(sort: Desc)])
  @@index([courseId, createdAt(sort: Desc)])
  @@index([userId])
}

// ============================================================
// FOLLOW
// ============================================================

model Follow {
  id          String       @id @default(cuid())
  followerId  String
  followingId String
  status      FollowStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())

  follower    User         @relation("Follower", fields: [followerId], references: [id])
  following   User         @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================
// MODERATION REPORT
// ============================================================

model ModerationReport {
  id             String           @id @default(cuid())
  reportedById   String
  reportedUserId String?
  uploadId       String?
  reason         ReportReason
  notes          String?
  status         ModerationStatus @default(PENDING)
  reviewedAt     DateTime?
  reviewedBy     String?
  createdAt      DateTime         @default(now())

  reportedBy     User             @relation("ReportedBy", fields: [reportedById], references: [id])
  reportedUser   User?            @relation("ReportedUser", fields: [reportedUserId], references: [id])
  upload         Upload?          @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([uploadId])
  @@index([reportedById])
}
// ============================================================
// GOLF TRIPS
// ============================================================

model GolfTrip {
  id          String           @id @default(cuid())
  name        String
  description String?
  startDate   String?
  endDate     String?
  imageUrl    String?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  creator     User             @relation("CreatedTrips", fields: [createdBy], references: [id])
  courses     GolfTripCourse[]
  members     GolfTripMember[]

  @@index([createdBy])
}

model GolfTripCourse {
  id            String   @id @default(cuid())
  tripId        String
  courseId      String
  playDate      String?
  teeTime       String?
  accommodation String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  trip          GolfTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
}

model GolfTripMember {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  role      String   @default("member")
  createdAt DateTime @default(now())

  trip      GolfTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User     @relation("TripMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([tripId])
  @@index([userId])
}

// ============================================================
// NOTIFICATION
// ============================================================

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  linkUrl     String?
  referenceId String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

// ============================================================
// SEARCH LOG
// ============================================================

model SearchLog {
  id          String   @id @default(cuid())
  query       String
  params      Json?
  resultIds   String[]
  resultCount Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())

  clicks      SearchClick[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model SearchClick {
  id          String    @id @default(cuid())
  searchLogId String
  courseId    String
  courseName  String
  position    Int
  userId      String?
  createdAt   DateTime  @default(now())

  searchLog   SearchLog @relation(fields: [searchLogId], references: [id], onDelete: Cascade)

  @@index([searchLogId])
  @@index([courseId])
  @@index([createdAt(sort: Desc)])
}

// ============================================================
// UPLOAD TAG
// ============================================================

model UploadTag {
  id        String   @id @default(cuid())
  uploadId  String
  userId    String
  approved  Boolean?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([uploadId, userId])
  @@index([uploadId])
  @@index([userId])
}

// ============================================================
// PROGRESSION SYSTEM
// ============================================================

model UserProgression {
  id            String    @id @default(cuid())
  userId        String    @unique
  totalPoints   Int       @default(0)
  level         Int       @default(1)
  rank          RankTier  @default(CADDIE)
  weeklyPoints  Int       @default(0)
  monthlyPoints Int       @default(0)
  streakWeeks   Int       @default(0)
  weekReset     DateTime?
  monthReset    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalPoints(sort: Desc)])
  @@index([weeklyPoints(sort: Desc)])
  @@index([monthlyPoints(sort: Desc)])
}

model UserPointsLedger {
  id          String   @id @default(cuid())
  userId      String
  action      String
  points      Int
  referenceId String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
}

model Badge {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String
  iconUrl     String?
  category    BadgeCategory
  rarity      BadgeRarity
  pointValue  Int           @default(0)
  requirement Json
  createdAt   DateTime      @default(now())

  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

model CourseContribution {
  id            String    @id @default(cuid())
  userId        String
  courseId      String
  uploadCount   Int       @default(0)
  firstUploadAt DateTime?
  lastUploadAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, uploadCount(sort: Desc)])
  @@index([userId])
}

model CourseFieldContribution {
  id        String   @id @default(cuid())
  courseId  String
  fieldName String
  userId    String
  awardedAt DateTime @default(now())

  @@unique([courseId, fieldName])
  @@index([userId])
  @@index([courseId])
}

model LeaderboardSnapshot {
  id          String            @id @default(cuid())
  period      LeaderboardPeriod
  periodStart DateTime
  periodEnd   DateTime
  userId      String
  rank        Int
  points      Int
  level       Int
  createdAt   DateTime          @default(now())

  @@index([period, periodStart])
  @@index([userId])
}

model RewardsWaitlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  notes     String?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model CourseRequest {
  id          String      @id @default(cuid())
  userId      String
  name        String
  city        String
  state       String
  courseType  CourseType?
  websiteUrl  String?
  notes       String?
  status      String      @default("PENDING")
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([status, createdAt(sort: Desc)])
}
